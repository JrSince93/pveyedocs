---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site';
---

<BaseLayout title="Privacy Policy" description="Notice of Privacy Practices for Paradise Valley Eye Docs, LLC.">

  <section class="hero-bg">
    <div class="container-x py-20 lg:py-28">
      <div class="max-w-3xl">
        <span class="eyebrow">Legal</span>
        <h1 class="font-display text-4xl sm:text-5xl mt-6 mb-8">Privacy Policy</h1>
        <span class="gold-rule"></span>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-white">
    <div class="container-x max-w-3xl">
      <div class="space-y-6 text-navy/80 leading-relaxed">
        <p class="text-lg">
          Paradise Valley Eye Docs, LLC is committed to protecting your privacy and complying with all applicable HIPAA regulations.
        </p>
        <p>
          <strong>Notice of Privacy Practices.</strong> Our full Notice of Privacy Practices is available for download below. It describes how medical information about you may be used and disclosed, and how you can access this information.
        </p>
        <p>
          <a href="/2025-Notice-of-Privacy-Practices.pdf" class="text-gold hover:text-gold-dark underline underline-offset-4" download>
            Download 2025 Notice of Privacy Practices (PDF)
          </a>
        </p>
        <p class="text-sm text-navy/60 italic">
          For questions or concerns regarding your privacy, contact us at {SITE.email} or {SITE.phone}.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
