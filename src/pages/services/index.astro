---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SERVICES } from '../../data/site';
import ServiceCard from '../../components/ServiceCard.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout title="Eye Care Services" description="Comprehensive eye exams, contact lens fittings, and advanced IPL/RF dry-eye treatment in Phoenix, AZ.">

  <section class="hero-bg">
    <div class="container-x py-20 lg:py-28">
      <div class="max-w-3xl">
        <span class="eyebrow">Services</span>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl mt-6 mb-8">Modern Eye Care.<br/><span class="text-gold">Tailored to You.</span></h1>
        <span class="gold-rule"></span>
        <p class="text-lg lg:text-xl text-navy/80 leading-relaxed">
          From routine exams to advanced dry-eye therapy — every service we offer is delivered with precision, expertise, and personalized attention.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-white">
    <div class="container-x">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {SERVICES.map((s) => (
          <ServiceCard slug={s.slug} name={s.name} short={s.short} icon={s.icon as 'eye' | 'contact' | 'drop'} featured={s.isFeatured} />
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
