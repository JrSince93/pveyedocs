---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, DOCTORS, SERVICES } from '../data/site';
import ServiceCard from '../components/ServiceCard.astro';
import DoctorCard from '../components/DoctorCard.astro';
import CTASection from '../components/CTASection.astro';

function formatTime(t: string | null): string {
  if (!t) return '';
  const [h, m] = t.split(':').map(Number);
  const period = h >= 12 ? 'pm' : 'am';
  const h12 = h % 12 || 12;
  return m === 0 ? `${h12}${period}` : `${h12}:${String(m).padStart(2, '0')}${period}`;
}
---

<BaseLayout title="Optometrists in Phoenix, AZ" description={SITE.description} pageType="home">

  <!-- HERO -->
  <section class="hero-bg relative overflow-hidden">
    <div class="container-x py-20 lg:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

        <div class="lg:col-span-7 animate-fade-up">
          <span class="eyebrow">Phoenix · Paradise Valley</span>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl xl:text-7xl mt-6 mb-8 leading-[1.1]">
            Clear Vision.<br/>
            <span class="text-gold">Better Life.</span>
          </h1>
          <span class="gold-rule"></span>
          <p class="text-lg lg:text-xl text-navy/80 leading-relaxed max-w-xl mb-10">
            Comprehensive eye care for every age. From routine exams to advanced IPL and Radiofrequency dry-eye treatment — delivered with warmth, expertise, and modern technology.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={`tel:${SITE.phoneRaw}`} class="btn-primary">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Call {SITE.phone}
            </a>
            <a href={SITE.intakeFormUrl} target="_blank" rel="noopener" class="btn-secondary">New Patient Intake</a>
          </div>

          <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-3 text-xs text-navy/60 uppercase tracking-extra-wide">
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              All ages welcome
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              Advanced dry-eye therapy
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              Open 6 days a week
            </span>
          </div>
        </div>

        <div class="lg:col-span-5 flex justify-center lg:justify-end animate-fade-in">
          <div class="relative">
            <div class="absolute -inset-4 -z-10 bg-gradient-to-br from-gold/25 to-sage/20 blur-3xl rounded-full"></div>
            <div class="relative aspect-[4/5] w-72 lg:w-96 overflow-hidden rounded-t-[140px] rounded-b-3xl shadow-2xl ring-1 ring-navy/10">
              <img
                src="https://images.unsplash.com/photo-1483519173755-be893fab1f46?q=80&w=1200&auto=format&fit=crop"
                alt="Close-up of a healthy human eye"
                class="w-full h-full object-cover"
                width="800"
                height="1000"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy/30 via-transparent to-transparent"></div>
            </div>
            <!-- Floating logo badge -->
            <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl p-4 ring-1 ring-navy/5">
              <img src="/logos/logo-icon.png" alt="" class="w-14 h-auto" width="56" height="56" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-navy text-white py-5">
    <div class="container-x">
      <p class="text-center text-sm lg:text-base">
        <span class="font-semibold text-gold uppercase tracking-extra-wide text-xs">Conveniently Located</span>
        <span class="mx-3 text-white/30">·</span>
        Inside the Paradise Valley Costco
        <span class="mx-3 text-white/30">·</span>
        4570 E Cactus Rd, Phoenix
      </p>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-white">
    <div class="container-x">
      <div class="max-w-2xl mb-16">
        <span class="eyebrow">What We Do</span>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl mt-6 mb-6">Modern Eye Care, Personalized.</h2>
        <span class="gold-rule"></span>
        <p class="text-lg text-navy/75 leading-relaxed">
          Whether you're due for a routine exam, exploring new contacts, or looking for real relief from chronic dry eye — our team brings expertise and warmth to every visit.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {SERVICES.map((s) => (
          <ServiceCard slug={s.slug} name={s.name} short={s.short} icon={s.icon as 'eye' | 'contact' | 'drop'} featured={s.isFeatured} />
        ))}
      </div>
    </div>
  </section>

  <section class="navy-bg text-white py-24 lg:py-32 relative overflow-hidden">
    <div class="container-x relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-6">
          <span class="eyebrow">Featured Treatment</span>
          <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl mt-6 mb-6 text-white">IPL & Radiofrequency<br/>for Chronic Dry Eye.</h2>
          <span class="gold-rule"></span>
          <p class="text-lg text-white/80 leading-relaxed mb-8">
            Burning, gritty, or watery eyes that won't quit? You're not alone — and you don't have to settle for endless drops. Our advanced IPL (Intense Pulsed Light) and Radiofrequency treatments target the <em>root causes</em> of dry eye: meibomian gland dysfunction, inflammation, and tear-film instability.
          </p>
          <ul class="space-y-3 mb-10 text-white/85">
            <li class="flex gap-3"><svg class="w-5 h-5 text-gold mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span>Non-invasive and comfortable in-office sessions</span></li>
            <li class="flex gap-3"><svg class="w-5 h-5 text-gold mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span>Targets the cause, not just the symptoms</span></li>
            <li class="flex gap-3"><svg class="w-5 h-5 text-gold mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span>Long-lasting relief for most patients</span></li>
            <li class="flex gap-3"><svg class="w-5 h-5 text-gold mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span>Designed for patients who haven't responded to drops alone</span></li>
          </ul>
          <a href="/services/dry-eye" class="btn-primary">Learn About Dry Eye Treatment</a>
        </div>

        <div class="lg:col-span-6">
          <div class="border border-gold/30 p-10 lg:p-14 bg-navy-600/40 backdrop-blur-sm">
            <div class="space-y-10">
              <div>
                <div class="font-display text-5xl lg:text-6xl text-gold mb-2">86%</div>
                <p class="text-sm text-white/70 uppercase tracking-extra-wide">of dry-eye cases are evaporative — caused by meibomian gland dysfunction</p>
              </div>
              <div class="h-px bg-white/15"></div>
              <div>
                <div class="font-display text-5xl lg:text-6xl text-gold mb-2">4–6</div>
                <p class="text-sm text-white/70 uppercase tracking-extra-wide">typical treatment sessions for lasting relief</p>
              </div>
              <div class="h-px bg-white/15"></div>
              <div>
                <div class="font-display text-5xl lg:text-6xl text-gold mb-2">Zero</div>
                <p class="text-sm text-white/70 uppercase tracking-extra-wide">recovery time — return to daily life right after</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/3 opacity-5 pointer-events-none">
      <img src="/logos/logo-icon.png" alt="" class="w-[600px] h-auto" />
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-cream">
    <div class="container-x">
      <div class="max-w-2xl mb-16">
        <span class="eyebrow">Meet Your Care Team</span>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl mt-6 mb-6">Doctors Who Listen.</h2>
        <span class="gold-rule"></span>
        <p class="text-lg text-navy/75 leading-relaxed">
          Three optometrists, decades of combined experience, and one shared commitment: care that's thorough, modern, and genuinely warm.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {DOCTORS.map((d) => (
          <DoctorCard slug={d.slug} name={d.name} role={d.role} headline={d.headline} image={d.image} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-white">
    <div class="container-x">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-6">
          <span class="eyebrow">Visit Us</span>
          <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl mt-6 mb-6">We're Easier to<br/>Find Than You Think.</h2>
          <span class="gold-rule"></span>
          <p class="text-lg text-navy/75 leading-relaxed mb-8">
            We're located right inside the Paradise Valley Costco at the corner of E Cactus Rd and N 44th St — with free parking, evening hours, and Saturday availability.
          </p>

          <div class="bg-cream border-l-4 border-gold p-6 mb-8">
            <h3 class="font-display text-base uppercase tracking-extra-wide mb-3">No Costco Membership Required</h3>
            <p class="text-navy/80 text-sm leading-relaxed">
              You do <strong>not</strong> need to be a Costco member to see one of our optometrists for an eye exam. We're an independent practice that leases space inside the warehouse — totally separate from Costco itself.
            </p>
          </div>

          <div class="space-y-4 text-navy">
            <div class="flex gap-4">
              <svg class="w-6 h-6 text-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <div class="font-semibold">{SITE.address.street}</div>
                <div class="text-navy/70 text-sm">{SITE.address.locality}, {SITE.address.region} {SITE.address.postal}</div>
              </div>
            </div>
            <div class="flex gap-4">
              <svg class="w-6 h-6 text-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <a href={`tel:${SITE.phoneRaw}`} class="font-semibold hover:text-gold transition-colors">{SITE.phone}</a>
            </div>
          </div>
        </div>

        <div class="lg:col-span-6">
          <div class="bg-navy text-white p-10 lg:p-12 h-full">
            <span class="eyebrow !text-gold">Office Hours</span>
            <h3 class="font-display text-2xl lg:text-3xl mt-4 mb-8 text-white">Open Six Days A Week</h3>
            <ul class="space-y-3 text-base">
              {SITE.hours.map((h) => (
                <li class="flex justify-between items-center pb-3 border-b border-white/15">
                  <span class="text-white/90">{h.day}</span>
                  <span class="font-semibold text-white">{h.open && h.close ? `${formatTime(h.open)} – ${formatTime(h.close)}` : 'Closed'}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection heading="See Clearly. Live Better." subheading="Call or text us today — most appointments available within the week." />
</BaseLayout>
