---
import BaseLayout from '../layouts/BaseLayout.astro';
import { DOCTORS } from '../data/site';
import DoctorCard from '../components/DoctorCard.astro';
import CTASection from '../components/CTASection.astro';

const values = [
  { title: 'Trustworthy', text: 'Reliable care you can count on, visit after visit.' },
  { title: 'Focused', text: 'Dedicated attention to your vision and your needs.' },
  { title: 'Bright', text: 'A positive outlook — for better tomorrows.' },
  { title: 'Welcoming', text: 'A warm, comfortable experience from the moment you walk in.' },
  { title: 'Compassionate', text: 'We care about you as a whole person — not just your eyes.' },
];
---

<BaseLayout title="About Our Practice" description="Learn about Paradise Valley Eye Docs — an independent optometry practice serving Phoenix from inside the Paradise Valley Costco. Owned by Dr. Nimo Yousuf, OD.">

  <section class="hero-bg">
    <div class="container-x py-20 lg:py-28">
      <div class="max-w-3xl">
        <span class="eyebrow">About Us</span>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl mt-6 mb-8">Focused on Your Vision.<br/><span class="text-gold">Committed to Your Care.</span></h1>
        <span class="gold-rule"></span>
        <p class="text-lg lg:text-xl text-navy/80 leading-relaxed">
          Paradise Valley Eye Docs is an independent optometry practice serving Phoenix and the surrounding Paradise Valley area — delivering modern, personalized eye care to patients of all ages.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-white">
    <div class="container-x">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-5">
          <span class="eyebrow">Our Story</span>
          <h2 class="font-display text-3xl sm:text-4xl mt-6 mb-6">Three Doctors.<br/>One Standard of Care.</h2>
          <span class="gold-rule"></span>
        </div>
        <div class="lg:col-span-7 space-y-6 text-base lg:text-lg text-navy/80 leading-relaxed">
          <p>
            Paradise Valley Eye Docs is owned and led by <strong>Dr. Nimo Yousuf, OD</strong>, a graduate of the Western University of Health Sciences College of Optometry. Her vision for the practice is simple: deliver thorough, expert eye care in a setting that feels warm and unhurried — and make that care easy to access for the community.
          </p>
          <p>
            Alongside Dr. Yousuf, our team includes <strong>Dr. Hannah Alegado, OD</strong>, a Midwestern University graduate with a strong clinical focus on dry-eye and ocular surface disease, and <strong>Dr. Scott B. Wayment, OD</strong>, a 22-year veteran with extensive experience co-managing LASIK and cataract surgery and fitting complex contact lens prescriptions.
          </p>
          <p>
            Together, we offer comprehensive eye exams, contact lens fittings, ocular disease management, and advanced IPL and Radiofrequency dry-eye treatment — all under one roof, with evening and Saturday hours that fit real life.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-cream">
    <div class="container-x">
      <div class="max-w-3xl mb-16">
        <span class="eyebrow">How It Works</span>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl mt-6 mb-6">Inside Costco.<br/>Independently Run.</h2>
        <span class="gold-rule"></span>
        <p class="text-lg text-navy/75 leading-relaxed">
          We're located inside the Paradise Valley Costco — but we operate as our own independent optometry practice. Here's what that means for you.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        <div class="bg-white p-8 lg:p-10 border-t-4 border-gold">
          <div class="font-display text-3xl text-gold mb-4">01</div>
          <h3 class="font-display text-xl mb-3">No Membership Required</h3>
          <p class="text-navy/75 leading-relaxed text-sm">
            You do not need a Costco membership to see one of our optometrists for an eye exam. We're a separate business that leases space inside the warehouse.
          </p>
        </div>
        <div class="bg-white p-8 lg:p-10 border-t-4 border-gold">
          <div class="font-display text-3xl text-gold mb-4">02</div>
          <h3 class="font-display text-xl mb-3">Our Own Doctors, Our Own Hours</h3>
          <p class="text-navy/75 leading-relaxed text-sm">
            Our doctors set their own schedules, fees, and accepted insurance plans. We're open six days a week, with evening hours on weekdays.
          </p>
        </div>
        <div class="bg-white p-8 lg:p-10 border-t-4 border-gold">
          <div class="font-display text-3xl text-gold mb-4">03</div>
          <h3 class="font-display text-xl mb-3">Convenience + Real Eye Care</h3>
          <p class="text-navy/75 leading-relaxed text-sm">
            You get a thorough, modern eye exam from a dedicated practice — and the convenience of free parking and a quick shopping trip after your visit.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-white">
    <div class="container-x">
      <div class="max-w-2xl mb-16">
        <span class="eyebrow">What We Stand For</span>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl mt-6 mb-6">Our Values.</h2>
        <span class="gold-rule"></span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8">
        {values.map((v) => (
          <div class="group">
            <div class="font-display text-sm uppercase tracking-extra-wide text-gold mb-3 pb-3 border-b border-warmgray-dark group-hover:border-gold transition-colors">{v.title}</div>
            <p class="text-navy/75 leading-relaxed text-sm">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-cream">
    <div class="container-x">
      <div class="max-w-2xl mb-16">
        <span class="eyebrow">Our Team</span>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl mt-6 mb-6">Meet Your Doctors.</h2>
        <span class="gold-rule"></span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {DOCTORS.map((d) => (
          <DoctorCard slug={d.slug} name={d.name} role={d.role} headline={d.headline} image={d.image} />
        ))}
      </div>
    </div>
  </section>

  <CTASection variant="navy" />
</BaseLayout>
