---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site';
---

<BaseLayout title="Accessibility Statement" description="Our commitment to digital accessibility at Paradise Valley Eye Docs.">

  <section class="hero-bg">
    <div class="container-x py-20 lg:py-28">
      <div class="max-w-3xl">
        <span class="eyebrow">Legal</span>
        <h1 class="font-display text-4xl sm:text-5xl mt-6 mb-8">Accessibility</h1>
        <span class="gold-rule"></span>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-white">
    <div class="container-x max-w-3xl">
      <div class="space-y-6 text-navy/80 leading-relaxed">
        <p class="text-lg">
          Paradise Valley Eye Docs is committed to making our website accessible to all visitors, regardless of ability.
        </p>
        <p>
          We have designed this site with accessibility in mind, including: semantic HTML structure, keyboard navigation, sufficient color contrast, descriptive alt text for images, and clear, readable typography.
        </p>
        <p>
          If you encounter any accessibility issues on our site, or need assistance accessing information, please contact us:
        </p>
        <ul class="space-y-2">
          <li><strong>Phone:</strong> <a href={`tel:${SITE.phoneRaw}`} class="text-gold hover:text-gold-dark">{SITE.phone}</a></li>
          <li><strong>Email:</strong> <a href={`mailto:${SITE.email}`} class="text-gold hover:text-gold-dark">{SITE.email}</a></li>
        </ul>
        <p>
          We are continually working to improve accessibility and welcome feedback from our community.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
