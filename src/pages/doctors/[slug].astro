---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { DOCTORS, SITE } from '../../data/site';
import CTASection from '../../components/CTASection.astro';

export function getStaticPaths() {
  return DOCTORS.map((d) => ({ params: { slug: d.slug }, props: { doctor: d } }));
}

const { doctor } = Astro.props;

const physicianSchema = {
  '@context': 'https://schema.org',
  '@type': 'Physician',
  name: doctor.name,
  jobTitle: doctor.role,
  medicalSpecialty: 'Optometric',
  alumniOf: { '@type': 'EducationalOrganization', name: doctor.school },
  worksFor: {
    '@type': 'MedicalBusiness',
    name: SITE.legalName,
    telephone: SITE.phone,
    address: {
      '@type': 'PostalAddress',
      streetAddress: SITE.address.street,
      addressLocality: SITE.address.locality,
      addressRegion: SITE.address.region,
      postalCode: SITE.address.postal,
    },
  },
};
---

<BaseLayout title={doctor.name} description={`${doctor.name} — ${doctor.role} at Paradise Valley Eye Docs in Phoenix, AZ. ${doctor.headline}`} pageType="doctor">

  <script type="application/ld+json" set:html={JSON.stringify(physicianSchema)} />

  <section class="hero-bg">
    <div class="container-x py-20 lg:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

        <div class="lg:col-span-7 order-2 lg:order-1">
          <a href="/doctors" class="inline-flex items-center text-gold text-xs uppercase tracking-extra-wide font-semibold mb-6 hover:text-gold-dark transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
            All Doctors
          </a>
          <span class="eyebrow">{doctor.role}</span>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl mt-6 mb-6 leading-[1.1]">{doctor.name}</h1>
          <span class="gold-rule"></span>
          <p class="text-lg lg:text-xl text-navy/80 leading-relaxed italic">{doctor.headline}</p>
          <p class="mt-6 text-sm text-navy/60 uppercase tracking-wider">
            <span class="font-semibold text-navy">Education:</span> {doctor.school}
          </p>
        </div>

        <div class="lg:col-span-5 order-1 lg:order-2">
          <div class="aspect-[4/5] bg-gradient-to-br from-warmgray to-warmgray-dark/40 overflow-hidden flex items-center justify-center relative">
            {doctor.image && doctor.image !== '/images/placeholder-doctor.jpg' ? (
              <img src={doctor.image} alt={doctor.name} class="w-full h-full object-cover" />
            ) : (
              <svg class="w-32 h-32 text-navy/15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-white">
    <div class="container-x">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-8 space-y-6 text-base lg:text-lg text-navy/80 leading-relaxed">
          <p>{doctor.bio}</p>
          <p>{doctor.bioSecond}</p>
          <p>{doctor.bioThird}</p>
        </div>

        <div class="lg:col-span-4">
          <div class="bg-cream p-8 lg:p-10 sticky top-32">
            <h2 class="font-display text-xl mb-6">Areas of Focus</h2>
            <ul class="space-y-3">
              {doctor.specialties.map((s: string) => (
                <li class="flex gap-3 text-navy/80 text-sm">
                  <svg class="w-5 h-5 text-gold mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span>{s}</span>
                </li>
              ))}
            </ul>
            <a href={`tel:${SITE.phoneRaw}`} class="btn-primary w-full mt-8 justify-center">Book With {doctor.shortName}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
