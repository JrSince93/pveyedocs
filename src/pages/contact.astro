---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site';

function formatTime(t: string | null): string {
  if (!t) return '';
  const [h, m] = t.split(':').map(Number);
  const period = h >= 12 ? 'pm' : 'am';
  const h12 = h % 12 || 12;
  return m === 0 ? `${h12}${period}` : `${h12}:${String(m).padStart(2, '0')}${period}`;
}

const directionsURL = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`${SITE.address.street}, ${SITE.address.locality}, ${SITE.address.region} ${SITE.address.postal}`)}`;
---

<BaseLayout title="Contact & Location" description={`Visit Paradise Valley Eye Docs at ${SITE.address.street}, ${SITE.address.locality}, ${SITE.address.region}. Call or text ${SITE.phone}.`}>

  <section class="hero-bg">
    <div class="container-x py-20 lg:py-28">
      <div class="max-w-3xl">
        <span class="eyebrow">Contact</span>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl mt-6 mb-8">Get in Touch.<br/><span class="text-gold">We'll Find a Time.</span></h1>
        <span class="gold-rule"></span>
        <p class="text-lg lg:text-xl text-navy/80 leading-relaxed">
          Call or text us to schedule. Most appointments are available within the week — and we're open six days a week to fit your schedule.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-white">
    <div class="container-x">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

        <div class="lg:col-span-5">
          <h2 class="font-display text-3xl mb-8">Reach Us Directly</h2>
          <div class="space-y-8">
            <a href={`tel:${SITE.phoneRaw}`} class="block group">
              <div class="flex gap-5 items-start">
                <div class="w-12 h-12 bg-gold/15 flex items-center justify-center flex-shrink-0 group-hover:bg-gold transition-colors">
                  <svg class="w-5 h-5 text-gold group-hover:text-navy transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <div class="text-xs uppercase tracking-extra-wide text-gold font-semibold mb-1">Call or Text</div>
                  <div class="font-display text-xl group-hover:text-gold transition-colors">{SITE.phone}</div>
                </div>
              </div>
            </a>

            <a href={`mailto:${SITE.email}`} class="block group">
              <div class="flex gap-5 items-start">
                <div class="w-12 h-12 bg-gold/15 flex items-center justify-center flex-shrink-0 group-hover:bg-gold transition-colors">
                  <svg class="w-5 h-5 text-gold group-hover:text-navy transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
                <div>
                  <div class="text-xs uppercase tracking-extra-wide text-gold font-semibold mb-1">Email</div>
                  <div class="font-display text-xl group-hover:text-gold transition-colors break-all">{SITE.email}</div>
                </div>
              </div>
            </a>

            <a href={directionsURL} target="_blank" rel="noopener" class="block group">
              <div class="flex gap-5 items-start">
                <div class="w-12 h-12 bg-gold/15 flex items-center justify-center flex-shrink-0 group-hover:bg-gold transition-colors">
                  <svg class="w-5 h-5 text-gold group-hover:text-navy transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <div class="text-xs uppercase tracking-extra-wide text-gold font-semibold mb-1">Visit Us</div>
                  <div class="font-display text-xl group-hover:text-gold transition-colors leading-snug">
                    {SITE.address.street}<br/>
                    {SITE.address.locality}, {SITE.address.region} {SITE.address.postal}
                  </div>
                  <div class="text-sm text-navy/60 italic mt-2">{SITE.address.insideOf}</div>
                </div>
              </div>
            </a>
          </div>
          <div class="mt-10">
            <a href={SITE.intakeFormUrl} target="_blank" rel="noopener" class="btn-primary">New Patient Intake Form</a>
          </div>
        </div>

        <div class="lg:col-span-7">
          <div class="bg-navy text-white p-10 lg:p-12">
            <span class="eyebrow !text-gold">Office Hours</span>
            <h3 class="font-display text-2xl lg:text-3xl mt-4 mb-8 text-white">When We're Open</h3>
            <ul class="space-y-3 text-base">
              {SITE.hours.map((h) => (
                <li class="flex justify-between items-center pb-3 border-b border-white/15">
                  <span class="text-white/90">{h.day}</span>
                  <span class="font-semibold text-white">{h.open && h.close ? `${formatTime(h.open)} – ${formatTime(h.close)}` : 'Closed'}</span>
                </li>
              ))}
            </ul>
            <div class="mt-10 pt-8 border-t border-white/20">
              <p class="text-sm text-white/75 leading-relaxed">
                <strong class="text-gold">No Costco membership required</strong> to see our optometrists for an eye exam. We're an independent practice that leases space inside the warehouse.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white pb-24 lg:pb-32">
    <div class="container-x">
      <div class="aspect-[16/9] lg:aspect-[21/9] w-full overflow-hidden">
        <iframe
          src={`https://www.google.com/maps/embed/v1/place?key=YOUR_API_KEY&q=${encodeURIComponent(`${SITE.address.street}, ${SITE.address.locality}, ${SITE.address.region} ${SITE.address.postal}`)}`}
          width="100%" height="100%" style="border:0;"
          allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
          title="Map to Paradise Valley Eye Docs"
        ></iframe>
      </div>
      <p class="text-center text-sm text-navy/60 mt-4">
        <a href={directionsURL} target="_blank" rel="noopener" class="text-gold hover:text-gold-dark underline underline-offset-4">Get directions on Google Maps →</a>
      </p>
    </div>
  </section>
</BaseLayout>
