---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  pageType?: 'home' | 'page' | 'doctor' | 'service';
}

const { title, description, pageType = 'page' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEO title={title} description={description} pageType={pageType} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-gold focus:text-navy focus:px-4 focus:py-2">
      Skip to content
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
