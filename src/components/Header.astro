---
import { SITE } from '../data/site';

const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Our Doctors', href: '/doctors' },
  { label: 'Services', href: '/services' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-warmgray-dark/40">
  <div class="container-x">
    <div class="flex items-center justify-between h-20 lg:h-24">

      <a href="/" class="flex items-center gap-3 group" aria-label={SITE.name}>
        <img
          src="/logos/logo-navbar.png"
          alt={SITE.name}
          class="h-14 lg:h-20 w-auto transition-transform duration-300 group-hover:scale-105"
          width="280"
          height="200"
        />
      </a>

      <nav class="hidden lg:flex items-center gap-10" aria-label="Primary">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class={`font-sans text-sm uppercase tracking-extra-wide font-medium transition-colors duration-300 ${
                isActive ? 'text-gold' : 'text-navy hover:text-gold'
              }`}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <div class="flex items-center gap-3">
        <a
          href={`tel:${SITE.phoneRaw}`}
          class="hidden md:inline-flex btn-primary text-xs lg:text-sm px-5 py-2.5"
          aria-label={`Call ${SITE.phone}`}
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span class="hidden lg:inline">Call Us</span>
          <span class="lg:hidden">Call</span>
        </a>

        <button
          id="mobile-menu-toggle"
          class="lg:hidden p-2 text-navy hover:text-gold transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden border-t border-warmgray-dark/40 bg-white">
    <nav class="container-x py-6 flex flex-col gap-1" aria-label="Mobile">
      {navItems.map((item) => (
        <a href={item.href} class="font-sans text-base uppercase tracking-extra-wide font-medium text-navy hover:text-gold py-3 border-b border-warmgray-dark/30">
          {item.label}
        </a>
      ))}
      <a href={`tel:${SITE.phoneRaw}`} class="btn-primary mt-4 w-full justify-center">Call {SITE.phone}</a>
      <a href={`sms:${SITE.phoneRaw}`} class="btn-secondary mt-3 w-full justify-center">Text Us</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
