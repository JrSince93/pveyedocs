---
interface Props {
  slug: string;
  name: string;
  role: string;
  headline: string;
  image?: string;
}
const { slug, name, role, headline } = Astro.props;
---

<a href={`/doctors/${slug}`} class="group block">
  <article class="card h-full flex flex-col relative overflow-hidden">
    <!-- Decorative top accent bar -->
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gold via-sage to-navy opacity-80"></div>

    <!-- Monogram badge -->
    <div class="w-16 h-16 rounded-full bg-gradient-to-br from-navy to-navy-400 flex items-center justify-center mb-6 mt-2">
      <span class="font-display text-xl text-white tracking-wide">
        {name.split(' ').filter((w) => w !== 'Dr.').map((w) => w[0]).join('')}
      </span>
    </div>

    <span class="eyebrow mb-3">{role}</span>
    <h3 class="font-display text-xl lg:text-2xl mb-3 group-hover:text-gold transition-colors">{name}</h3>
    <p class="text-navy/75 leading-relaxed text-sm flex-1">{headline}</p>
    <div class="mt-6 inline-flex items-center text-gold text-xs uppercase tracking-extra-wide font-semibold">
      Read Bio
      <svg class="w-4 h-4 ml-2 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </article>
</a>
