---
interface Props {
  slug: string;
  name: string;
  role: string;
  headline: string;
  image?: string;
}
const { slug, name, role, headline, image } = Astro.props;
---

<a href={`/doctors/${slug}`} class="group block">
  <article class="card h-full flex flex-col">
    <div class="aspect-[4/5] bg-gradient-to-br from-warmgray to-warmgray-dark/40 mb-6 overflow-hidden flex items-center justify-center">
      {image && image !== '/images/placeholder-doctor.jpg' ? (
        <img src={image} alt={name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
      ) : (
        <svg class="w-24 h-24 text-navy/15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
      )}
    </div>

    <span class="eyebrow mb-3">{role}</span>
    <h3 class="font-display text-xl lg:text-2xl mb-3 group-hover:text-gold transition-colors">{name}</h3>
    <p class="text-navy/75 leading-relaxed text-sm flex-1">{headline}</p>
    <div class="mt-6 inline-flex items-center text-gold text-xs uppercase tracking-extra-wide font-semibold">
      Read Bio
      <svg class="w-4 h-4 ml-2 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </article>
</a>
