---
import { SITE } from '../data/site';

interface Props {
  heading?: string;
  subheading?: string;
  variant?: 'navy' | 'cream';
}

const {
  heading = 'Ready to see clearly?',
  subheading = "Schedule your exam today. Call or text us — we'll find a time that works for you.",
  variant = 'navy',
} = Astro.props;

const isNavy = variant === 'navy';
---

<section class={isNavy ? 'navy-bg text-white' : 'bg-cream text-navy'}>
  <div class="container-x py-20 lg:py-28 text-center">
    <h2 class={`font-display text-3xl sm:text-4xl lg:text-5xl mb-6 ${isNavy ? 'text-white' : 'text-navy'}`}>
      {heading}
    </h2>
    <p class={`max-w-2xl mx-auto text-base lg:text-lg leading-relaxed mb-10 ${isNavy ? 'text-white/85' : 'text-navy/80'}`}>
      {subheading}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={`tel:${SITE.phoneRaw}`} class="btn-primary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call {SITE.phone}
      </a>
      <a
        href={SITE.intakeFormUrl}
        target="_blank"
        rel="noopener"
        class={isNavy
          ? 'inline-flex items-center justify-center gap-2 border-2 border-white text-white bg-transparent font-sans font-semibold px-7 py-3.5 text-sm uppercase tracking-extra-wide transition-all duration-300 hover:bg-white hover:text-navy'
          : 'btn-secondary'}
      >
        New Patient Intake Form
      </a>
    </div>
  </div>
</section>
